---
import { navigationItems, isDropdown } from '../../data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function isDropdownActive(items: { href: string }[]): boolean {
  return items.some(item => currentPath.startsWith(item.href));
}
---

<!-- Mobile menu button -->
<button 
  type="button" 
  class="md:hidden text-brand-orange hover:text-brand-orange-light transition-colors"
  aria-label="Abrir menú de navegación"
  aria-expanded="false"
  id="mobile-menu-button"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>

<!-- Mobile menu panel -->
<div 
  id="mobile-menu" 
  class="md:hidden fixed inset-0 z-60 bg-black/30 backdrop-blur-sm opacity-0 invisible transition-all duration-300"
  aria-hidden="true"
>
  <div class="fixed right-0 top-0 bottom-0 w-80 max-w-[85vw] bg-bg-white shadow-xl transform translate-x-full transition-transform duration-300">
    <div class="flex items-center justify-between p-4 border-b border-border-light">
      <span class="text-lg font-bold text-text-dark">Menú</span>
      <button 
        type="button"
        id="mobile-menu-close"
        class="text-text-dark hover:text-brand-orange transition-colors"
        aria-label="Cerrar menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <nav class="overflow-y-auto h-[calc(100vh-73px)]" aria-label="Navegación móvil">
      <ul class="p-4 space-y-2">
        {navigationItems.map((item) => {
          if (isDropdown(item)) {
            const isActiveDropdown = isDropdownActive(item.items);
            return (
              <li>
                <button 
                  type="button"
                  class={`mobile-dropdown-toggle w-full flex items-center justify-between px-4 py-3 hover:bg-hover-bg hover:text-brand-orange rounded-lg transition-colors ${
                    isActiveDropdown 
                      ? 'text-brand-orange font-semibold' 
                      : 'text-text-base'
                  }`}
                  aria-expanded="false"
                >
                  <span>{item.label}</span>
                  <svg class="w-4 h-4 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
                <ul class="mobile-dropdown-menu hidden pl-4 mt-2 space-y-2">
                  {item.items.map(subItem => (
                    <li>
                      <a 
                        href={subItem.href} 
                        class={`block px-4 py-2 hover:bg-hover-bg hover:text-brand-orange rounded-lg transition-colors ${
                          isActive(subItem.href) 
                            ? 'text-brand-orange font-semibold' 
                            : 'text-text-base'
                        }`}
                      >
                        {subItem.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            );
          } else {
            return (
              <li>
                <a 
                  href={item.href} 
                  class={`block px-4 py-3 hover:bg-hover-bg hover:text-brand-orange rounded-lg transition-colors ${
                    isActive(item.href) 
                      ? 'text-brand-orange font-semibold bg-hover-bg' 
                      : 'text-text-base'
                  }`}
                >
                  {item.label}
                </a>
              </li>
            );
          }
        })}
      </ul>
    </nav>
  </div>
</div>

<script>
  // Mobile menu functionality
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuPanel = mobileMenu?.querySelector('div');
    
    function openMobileMenu() {
      if (!mobileMenu || !mobileMenuPanel) return;
      mobileMenu.classList.remove('invisible', 'opacity-0');
      mobileMenuPanel.classList.remove('translate-x-full');
      mobileMenu.setAttribute('aria-hidden', 'false');
      mobileMenuButton?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      
      // Focus first link
      const firstLink = mobileMenu.querySelector('a');
      setTimeout(() => firstLink?.focus(), 100);
    }
    
    function closeMobileMenu() {
      if (!mobileMenu || !mobileMenuPanel) return;
      mobileMenu.classList.add('opacity-0');
      mobileMenuPanel.classList.add('translate-x-full');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      
      setTimeout(() => {
        mobileMenu.classList.add('invisible');
      }, 300);
      
      mobileMenuButton?.focus();
    }
    
    mobileMenuButton?.addEventListener('click', openMobileMenu);
    mobileMenuClose?.addEventListener('click', closeMobileMenu);
    
    // Close on overlay click
    mobileMenu?.addEventListener('click', (e) => {
      if (e.target === mobileMenu) closeMobileMenu();
    });
    
    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu?.getAttribute('aria-hidden') === 'false') {
        closeMobileMenu();
      }
    });
    
    // Mobile dropdowns
    const mobileDropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');
    mobileDropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const menu = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
        
        if (isExpanded) {
          menu?.classList.add('hidden');
          icon?.classList.remove('rotate-180');
          toggle.setAttribute('aria-expanded', 'false');
        } else {
          menu?.classList.remove('hidden');
          icon?.classList.add('rotate-180');
          toggle.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
