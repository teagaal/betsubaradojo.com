---
interface Props {
  background?: 'white' | 'light' | 'lighter' | 'dark';
  class?: string;
}

const { background = 'white', class: className = '' } = Astro.props;

const bgClasses = {
  white: 'bg-bg-white',
  light: 'bg-bg-light',
  lighter: 'bg-bg-lighter',
  dark: 'bg-bg-dark'
};
---

<section class={bgClasses[background]}>
  <div class={`container mx-auto px-4 py-16 ${className}`}>
    <slot />
  </div>
</section>

