---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const disciplinas = [
  { name: 'Abordaje corporal', instagram: 'tierrapeuta' },
  { name: 'Aikido', instagram: 'shuhari_dojo' },
  { name: 'Ashtanga yoga', instagram: 'uminoshi' },
  { name: 'Entrenamiento corporal integral', instagram: 'm.marisavillar' },
  { name: 'Jiu Jitsu brasileño', instagram: 'tomasbombachi' },
  { name: 'Judo', instagram: null },
  { name: 'Karate shorin ryu', instagram: 'hikari_dojo_karate_do' },
  { name: 'Karate shotokan', instagram: 'lemoskarate' },
  { name: 'Kung fu adultos', instagram: 'zailu.chienmovimiento' },
  { name: 'Kung fu entre mujeres', instagram: 'katrinurwitz' },
  { name: 'Kung fu infantiles', instagram: ['escuela_shaolien', 'merlinateka'] },
  { name: 'Pakua', instagram: 'miguelpakua' },
  { name: 'Taekwondo', instagram: 'fercasastkd' },
  { name: 'Taichi y chikung', instagram: 'zailu.chienmovimiento' },
  { name: 'Yoga vinyasa', instagram: 'beayoguini' },
];
---

<BaseLayout title="Disciplinas | Betsubara Dojo">
  <Section>
    <h1 class="text-5xl font-bold text-black mb-12 text-center">Nuestras disciplinas</h1>
    
    <div class="max-w-3xl mx-auto">
      {disciplinas.map((disciplina) => (
        <div class="flex justify-between items-center py-3 px-2 border-b border-brand-orange/20">
          <span class="text-xl text-black font-medium">{disciplina.name}</span>
          {disciplina.instagram && (
            Array.isArray(disciplina.instagram) ? (
              <div class="flex gap-sm">
                {disciplina.instagram.map((handle, index) => (
                  <>
                    <a 
                      href={`https://instagram.com/${handle}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-brand-orange hover:text-brand-orange-light transition-colors"
                    >
                      @{handle}
                    </a>
                    {index < disciplina.instagram.length - 1 && (
                      <span class="text-text-base">/</span>
                    )}
                  </>
                ))}
              </div>
            ) : (
              <a 
                href={`https://instagram.com/${disciplina.instagram}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand-orange hover:text-brand-orange-light transition-colors"
              >
                @{disciplina.instagram}
              </a>
            )
          )}
        </div>
      ))}
    </div>
  </Section>
</BaseLayout>

